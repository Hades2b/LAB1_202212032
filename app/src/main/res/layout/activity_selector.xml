<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <include layout="@layout/toolbar"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bienvenido"
            android:textAlignment="center"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="20dp"
            android:textSize="40sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/nombre_display"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textAlignment="center"
            android:layout_marginBottom="40dp"
            android:textSize="20sp"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecciona una dificultad:"
            android:textAlignment="center"
            android:layout_marginTop="60dp"
            android:layout_marginBottom="40dp"
            android:textSize="20sp"/>

        <Button
            android:id="@+id/btn_facil"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:onClick="jugarFacil"
            android:textSize="20sp"
            android:backgroundTint="@color/verde_elements"
            android:text="Fácil" />

        <Button
            android:id="@+id/btn_dificil"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp"
            android:onClick="jugarDificil"
            android:textSize="20sp"
            android:backgroundTint="@color/rojo_elements"
            android:text="Difícil" />

        <Button
            android:id="@+id/btn_aleatorio"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:onClick="jugarAleatorio"
            android:textSize="20sp"
            android:backgroundTint="@color/amarillo_text"
            android:text="Aleatorio" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>